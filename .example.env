# Rubika Bot Token (get from @BotFather on Rubika)
RUBIKA_BOT_TOKEN=your_rubika_bot_token_here

# Rubika Bot API base URL
RUBIKA_API_URL=https://botapi.rubika.ir/v3

# Gemini API Key (get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-1.5-flash

# Admin Rubika user ID
ADMIN_USER_ID=your_admin_user_id

# Webhook settings (your Render app URL)
WEBHOOK_URL=https://your-app-name.onrender.com

# Port for Flask server
PORT=5000

# Secret token for webhook security
WEBHOOK_SECRET=your_random_secret_string_here
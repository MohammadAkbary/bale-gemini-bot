# Bale Bot Token (get from @BotFather on Bale)
BALE_BOT_TOKEN=your_bale_bot_token_here

# Bale Bot API base URL (Bale uses its own API endpoint)
BALE_API_URL=https://tapi.bale.ai/bot

# Gemini API Key (get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-1.5-flash

# Admin Telegram/Bale user ID (numeric ID of the admin)
ADMIN_USER_ID=123456789

# Admin username (without @)
ADMIN_USERNAME=your_admin_username

# Webhook settings (your Render app URL)
WEBHOOK_URL=https://your-app-name.onrender.com

# Port for Flask server
PORT=5000

# Secret token for webhook security
WEBHOOK_SECRET=your_random_secret_string_here